{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "allow-yt-dlp",
  "description": "Allow executing yt-dlp",
  "windows": [
    "main"
  ],
  "permissions": [
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "yt-dlp",
          "cmd": "yt-dlp",
          "args": true
        }
      ]
    },
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "yt-dlp",
          "cmd": "yt-dlp",
          "args": true
        }
      ]
    }
  ]
}
